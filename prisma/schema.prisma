generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  role      String   @default("ADMIN")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  posts     Post[]
}

model Post {
  id            String    @id @default(cuid())
  title         String
  slug          String    @unique
  content       String
  excerpt       String?
  coverImage    String?
  published     Boolean   @default(false)
  featured      Boolean   @default(false)
  authorId      String
  author        User      @relation(fields: [authorId], references: [id])
  categoryId    String?
  category      Category? @relation(fields: [categoryId], references: [id])
  customUrl     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([slug])
}

model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  icon      String?  @default("Newspaper")
  posts     Post[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SiteSettings {
  id               String   @id @default("singleton")
  siteName         String?  @default("SMART TECH")
  siteTitle        String?  @default("GUIDE")
  logoUrl          String?  @default("https://res.cloudinary.com/dj9m8f8u6/image/upload/v1712520000/default-logo.png")
  heroTitle        String?
  heroSubtitle     String?
  exploreTitle     String?  @default("EXPLORE OUR GUIDES")
  exploreSubtitle  String?  @default("Hand-picked categories to help you master your PC and discover the latest tech secrets.")
  stayUpdatedTitle String?  @default("Stay Updated")
  stayUpdatedSubtitle String? @default("Get the latest PC tips, tech news, and freebies delivered straight to your inbox.")
  footerTitle      String?  @default("SmartTech Guide")
  footerSubtitle   String?  @default("Smart Tips, Better You.")
  socialLinkFacebook String? @default("https://www.facebook.com/smarttechguide/")
  socialLinks      String?  @default("[{\"platform\":\"Facebook\",\"url\":\"https://www.facebook.com/smarttechguide/\"}]")
  heroStatusText     String?  @default("# SYSTEM READY // SMART_TIPS_V2.0")
  heroButton1Text    String?  @default("INITIALIZE")
  heroButton1Link    String?  @default("#explore")
  heroButton2Text    String?  @default("CONNECT_NET")
  heroButton2Link    String?  @default("/category/free-games")
  splashTopLeft      String?  @default("SYS.VER.2.0.4 // BOOT_SEQ")
  splashTopRight     String?  @default("AUTH: OVERRIDE_ACTV")
  splashBottomLeft   String?  @default("CPU: OVERRIDE")
  splashBottomRight  String?  @default("SEC: UNLOCKED")
  splashLogs         String?  // JSON string
  tickerItems      String?  // JSON string of items
  footerText       String?
  updatedAt        DateTime @updatedAt
}
